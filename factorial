package com.example.factorial;

import android.os.Bundle;
import android.widget.Button;
import android.widget.EditText;
import android.widget.TextView;
import androidx.appcompat.app.AppCompatActivity;
import java.math.BigInteger;

public class MainActivity extends AppCompatActivity {

    private EditText inputNumber;
    private Button calculateButton;
    private TextView outputView;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        initializeViews();
        setupButtonAction();
    }

    private void initializeViews() {
        inputNumber = findViewById(R.id.num);
        calculateButton = findViewById(R.id.fact);
        outputView = findViewById(R.id.result);
    }

    private void setupButtonAction() {
        calculateButton.setOnClickListener(v -> processFactorial());
    }

    private void processFactorial() {
        String value = inputNumber.getText().toString().trim();

        if (value.length() == 0) {
            outputView.setText("Enter a valid number");
            return;
        }

        try {
            int num = Integer.parseInt(value);

            if (num < 0) {
                outputView.setText("Negative numbers not allowed");
                return;
            }

            outputView.setText("Result:\n" + computeFactorial(num));

        } catch (NumberFormatException e) {
            outputView.setText("Invalid input");
        }
    }

    private BigInteger computeFactorial(int n) {
        BigInteger result = BigInteger.ONE;

        for (int i = 2; i <= n; i++) {
            result = result.multiply(BigInteger.valueOf(i));
        }

        return result;
    }
}
