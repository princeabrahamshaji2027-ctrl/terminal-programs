PROGRAM 2: AGGREGATE + ORDER BY + GROUP BY + HAVING
-- Create table
CREATE TABLE orders (
    order_id INT PRIMARY KEY,
    customer_name VARCHAR(50),
    amount INT,
    city VARCHAR(50)
);

-- Insert data
INSERT INTO orders VALUES
(1, 'A', 200, 'Kochi'),
(2, 'B', 500, 'Kochi'),
(3, 'C', 300, 'Trivandrum'),
(4, 'D', 700, 'Kochi');

-- Aggregate functions
SELECT COUNT(*) FROM orders;           -- total rows
SELECT SUM(amount) FROM orders;        -- total amount
SELECT AVG(amount) FROM orders;        -- average
SELECT MAX(amount) FROM orders;        -- highest
SELECT MIN(amount) FROM orders;        -- lowest

-- DISTINCT values
SELECT DISTINCT city FROM orders;

-- ORDER BY sorting
SELECT * FROM orders ORDER BY amount;        -- ascending
SELECT * FROM orders ORDER BY amount DESC;   -- descending

-- GROUP BY (group data)
SELECT city, SUM(amount)
FROM orders
GROUP BY city;

-- HAVING (filter grouped data)
SELECT city, SUM(amount)
FROM orders
GROUP BY city
HAVING SUM(amount) > 500;
