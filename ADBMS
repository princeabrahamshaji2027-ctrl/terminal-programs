PROGRAM 3: ADVANCED (SUBQUERY + EXTRA CONDITIONS)
-- Create table
CREATE TABLE employee (
    id INT PRIMARY KEY,
    name VARCHAR(50),
    salary INT,
    dept VARCHAR(50)
);

-- Insert data
INSERT INTO employee VALUES
(1, 'A', 10000, 'HR'),
(2, 'B', 15000, 'IT'),
(3, 'C', 8000, 'HR'),
(4, 'D', 20000, 'IT');

-- IN condition
SELECT * FROM employee WHERE dept IN ('HR', 'IT');

-- NOT IN
SELECT * FROM employee WHERE dept NOT IN ('HR');

-- Subquery (important)
SELECT name FROM employee
WHERE salary > (SELECT AVG(salary) FROM employee);

-- Top value (highest salary)
SELECT name FROM employee ORDER BY salary DESC LIMIT 1;

-- Calculated column
SELECT name, (salary * 12) AS yearly_salary FROM employee;
