package com.example.myapplication;

import android.content.Intent;
import android.os.Bundle;
import android.widget.Button;
import android.widget.EditText;

import androidx.appcompat.app.AppCompatActivity;

public class Activity2 extends AppCompatActivity {

    EditText m1, m2, m3;
    Button btnCalc;

    String name, roll;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_2);

        m1 = findViewById(R.id.m1);
        m2 = findViewById(R.id.m2);
        m3 = findViewById(R.id.m3);
        btnCalc = findViewById(R.id.btnCalc);

        Intent intent = getIntent();
        name = intent.getStringExtra("name");
        roll = intent.getStringExtra("roll");

        btnCalc.setOnClickListener(v -> {

            String s1 = m1.getText().toString().trim();
            String s2 = m2.getText().toString().trim();
            String s3 = m3.getText().toString().trim();

            if (s1.isEmpty() || s2.isEmpty() || s3.isEmpty()) {
                m1.setError("Enter marks");
                m2.setError("Enter marks");
                m3.setError("Enter marks");
                return;
            }

            int mark1 = Integer.parseInt(s1);
            int mark2 = Integer.parseInt(s2);
            int mark3 = Integer.parseInt(s3);

            int total = mark1 + mark2 + mark3;
            double average = total / 3.0;

            Intent i = new Intent(Activity2.this, Activity3.class);
            i.putExtra("name", name);
            i.putExtra("roll", roll);
            i.putExtra("total", total);
            i.putExtra("average", average);

            startActivity(i);
        });
    }
}

