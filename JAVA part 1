7. Cinema Ticket Booking
interface Refundable {
    void refund();
}

class Seat {
    String seatNo;

    Seat(String seatNo) {
        this.seatNo = seatNo;
    }

    void getPrice() {
        System.out.println("Seat price");
    }

    class SnackOrder {
        void orderSnack() {
            System.out.println("Snack ordered for seat " + seatNo);
        }
    }
}

class RegularSeat extends Seat implements Refundable {
    RegularSeat(String seatNo) {
        super(seatNo);
    }

    @Override
    void getPrice() {
        System.out.println("Regular seat = 150");
    }

    public void refund() {
        System.out.println("Refund done");
    }
}

class VIPSeat extends Seat {
    VIPSeat(String seatNo) {
        super(seatNo);
    }

    @Override
    void getPrice() {
        System.out.println("VIP seat = 300");
    }
}

class SeatThread extends Thread {
    String user;

    SeatThread(String user) {
        this.user = user;
    }

    public void run() {
        System.out.println(user + " booked a seat");
    }
}

public class CinemaTicketBooking {
    public static void main(String[] args) {
        String seats[] = {"A1", "A2", "B1"};

        RegularSeat r = new RegularSeat("A1");
        VIPSeat v = new VIPSeat("B1");

        r.getPrice();
        v.getPrice();
        r.refund();

        Seat.SnackOrder s = r.new SnackOrder();
        s.orderSnack();

        new SeatThread("User1").start();
        new SeatThread("User2").start();
    }
}











