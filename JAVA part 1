1. Smart Transport System
interface Schedulable {
    void setSchedule();
}

class Vehicle {
    String passengerName;

    Vehicle(String passengerName) {
        this.passengerName = passengerName;
    }

    void calculateFare() {
        System.out.println("Vehicle fare");
    }
}

class Bus extends Vehicle implements Schedulable {
    Bus(String passengerName) {
        super(passengerName);
    }

    void calculateFare() {
        System.out.println("Bus fare = 50");
    }

    public void setSchedule() {
        System.out.println("Bus schedule set");
    }
}

class Train extends Vehicle implements Schedulable {
    Train(String passengerName) {
        super(passengerName);
    }

    void calculateFare() {
        System.out.println("Train fare = 100");
    }

    public void setSchedule() {
        System.out.println("Train schedule set");
    }
}

class Ticket {
    void printTicket() {
        System.out.println("Ticket booked");
    }
}

class BookingThread extends Thread {
    String name;

    BookingThread(String name) {
        this.name = name;
    }

    public void run() {
        System.out.println(name + " booked ticket");
    }
}

public class SmartTransportSystem {
    public static void main(String[] args) {
        Bus b = new Bus("Arun");
        Train t = new Train("Rahul");

        b.calculateFare();
        t.calculateFare();

        b.setSchedule();
        t.setSchedule();

        String passengers[] = {"Arun", "Rahul", "Maya"};
        String search = "Rahul";
        int found = 0;

        for (int i = 0; i < passengers.length; i++) {
            if (passengers[i].equals(search)) {
                found = 1;
                break;
            }
        }

        if (found == 1)
            System.out.println(search + " found");
        else
            System.out.println(search + " not found");

        Ticket tk = new Ticket();
        tk.printTicket();

        BookingThread t1 = new BookingThread("Passenger1");
        BookingThread t2 = new BookingThread("Passenger2");

        t1.start();
        t2.start();
    }
}
