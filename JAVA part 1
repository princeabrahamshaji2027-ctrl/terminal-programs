1. Smart Transport System
interface Schedulable {
    void setSchedule();
}

class Vehicle {
    String name;

    Vehicle(String name) {
        this.name = name;
    }

    void calculateFare() {
        System.out.println("Vehicle fare");
    }

    class Ticket {
        void showTicket() {
            System.out.println("Ticket booked for " + name);
        }
    }
}

class Bus extends Vehicle implements Schedulable {
    Bus(String name) {
        super(name);
    }

    @Override
    void calculateFare() {
        System.out.println("Bus fare = 50");
    }

    public void setSchedule() {
        System.out.println("Bus schedule set");
    }
}

class Train extends Vehicle {
    Train(String name) {
        super(name);
    }

    @Override
    void calculateFare() {
        System.out.println("Train fare = 100");
    }
}

class BookingThread extends Thread {
    String passenger;

    BookingThread(String passenger) {
        this.passenger = passenger;
    }

    public void run() {
        System.out.println(passenger + " booked ticket");
    }
}

public class SmartTransportSystem {
    public static void main(String[] args) {
        String passengers[] = {"Aju", "Binu", "Ciya"};

        for (String p : passengers) {
            System.out.println(p);
        }

        String search = "Binu";
        for (String p : passengers) {
            if (p.equals(search)) {
                System.out.println(search + " found");
            }
        }

        Bus b = new Bus("City Bus");
        Train t = new Train("Express Train");

        b.calculateFare();
        t.calculateFare();
        b.setSchedule();

        Vehicle.Ticket tk = b.new Ticket();
        tk.showTicket();

        new BookingThread("Aju").start();
        new BookingThread("Binu").start();
    }
}
