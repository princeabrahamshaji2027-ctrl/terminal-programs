5. Library Automation
interface Downloadable {
    void download();
}

class Book {
    String title;

    Book(String title) {
        this.title = title;
    }

    void getAvailability() {
        System.out.println("Book available");
    }

    class Membership {
        void showMember() {
            System.out.println("Membership active for " + title);
        }
    }
}

class DigitalBook extends Book implements Downloadable {
    DigitalBook(String title) {
        super(title);
    }

    @Override
    void getAvailability() {
        System.out.println("Digital book available online");
    }

    public void download() {
        System.out.println("Book downloaded");
    }
}

class PrintedBook extends Book {
    PrintedBook(String title) {
        super(title);
    }

    @Override
    void getAvailability() {
        System.out.println("Printed book available in library");
    }
}

class IssueThread extends Thread {
    String user;

    IssueThread(String user) {
        this.user = user;
    }

    public void run() {
        System.out.println(user + " issued a book");
    }
}

public class LibraryAutomation {
    public static void main(String[] args) {
        String titles[] = {"Java", "DBMS", "OS"};
        for (String t : titles) {
            System.out.println(t);
        }

        DigitalBook d = new DigitalBook("Java");
        PrintedBook p = new PrintedBook("DBMS");

        d.getAvailability();
        p.getAvailability();
        d.download();

        Book.Membership m = d.new Membership();
        m.showMember();

        new IssueThread("User1").start();
        new IssueThread("User2").start();
    }
}
