        }
    }
}

class DomesticFlight extends Flight implements Cancellable {
    DomesticFlight(String name) {
        super(name);
    }

    @Override
    void calculateFare() {
        System.out.println("Domestic fare = 3000");
    }

    public void cancelTicket() {
        System.out.println("Domestic ticket cancelled");
    }
}

class InternationalFlight extends Flight {
    InternationalFlight(String name) {
        super(name);
