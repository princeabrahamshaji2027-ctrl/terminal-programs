3. Online Shopping Cart
interface Shippable {
    void shipProduct();
}

class Product {
    String name;

    Product(String name) {
        this.name = name;
    }

    void applyDiscount() {
        System.out.println("General discount");
    }

    class Review {
        void showReview() {
            System.out.println("Review added for " + name);
        }
    }
}

class Electronics extends Product implements Shippable {
    Electronics(String name) {
        super(name);
    }

    @Override
    void applyDiscount() {
        System.out.println("Electronics discount = 10%");
    }

    public void shipProduct() {
        System.out.println("Electronics shipped");
    }
}

class Clothing extends Product {
    Clothing(String name) {
        super(name);
    }

    @Override
    void applyDiscount() {
        System.out.println("Clothing discount = 20%");
    }
}

class CartThread extends Thread {
    String customer;

    CartThread(String customer) {
        this.customer = customer;
    }

    public void run() {
        System.out.println(customer + " added item to cart");
    }
}

public class OnlineShoppingCart {
    public static void main(String[] args) {
        String products[] = {"Laptop", "Shirt", "Phone"};

        for (String p : products) {
            System.out.println(p);
        }

        String search = "Phone";
        for (String p : products) {
            if (p.equals(search)) {
                System.out.println(search + " found");
            }
        }

        Electronics e = new Electronics("Laptop");
        Clothing c = new Clothing("Shirt");

        e.applyDiscount();
        c.applyDiscount();
        e.shipProduct();

        Product.Review r = e.new Review();
        r.showReview();

        new CartThread("Customer1").start();
        new CartThread("Customer2").start();
