import java.util.Scanner;

public class MegaProgram2 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        String[] questions = {
            "Capital of India?",
            "2 + 2?",
            "Java keyword for inheritance?"
        };

        String[][] options = {
            {"1.Delhi","2.Mumbai","3.Kolkata","4.Chennai"},
            {"1.3","2.4","3.5","4.6"},
            {"1.extend","2.extends","3.inherit","4.super"}
        };

        int[] answers = {1,2,2};
        int score = 0;

        for(int i=0;i<questions.length;i++){
            System.out.println(questions[i]);

            for(int j=0;j<4;j++){
                System.out.println(options[i][j]); // print options
            }

            int user = sc.nextInt();

            if(user == answers[i]){ // checking answer
                score++;
            }
        }

        System.out.println("Final Score: " + score);

        sc.close();
    }
}

PROGRAM 3 (Full OOP + Thread):
// Interface
interface Animal {
    void sound();
}

// Abstract Class
abstract class Shape {
    abstract double area();
}

// Class + Inheritance
class Dog implements Animal {
    public void sound() {
        System.out.println("Dog barks");
    }
}

// Method Overloading
class Calc {
    void sum(int a, int b){
        System.out.println("Sum: " + (a+b));
    }

    void sum(int a, int b, int c){
        System.out.println("Sum: " + (a+b+c));
    }
}

// Abstract Implementation
class Circle extends Shape {
    int r;
    Circle(int r){
        this.r = r;
    }

    double area(){
        return 3.14 * r * r;
    }
}

// Thread
class MyThread extends Thread {
    public void run(){
        System.out.println("Thread running...");
    }
}

public class MegaProgram3 {
    public static void main(String[] args) {

        // Interface
        Dog d = new Dog();
        d.sound();

        // Overloading
        Calc c = new Calc();
        c.sum(2,3);
        c.sum(2,3,4);

        // Abstract
        Circle obj = new Circle(5);
        System.out.println("Area: " + obj.area());

        // Thread
        MyThread t = new MyThread();
        t.start();
    }
}
