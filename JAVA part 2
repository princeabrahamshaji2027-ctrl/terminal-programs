8. Smart Home Automation
interface Controllable {
    void control();
}

class Device {
    String name;

    Device(String name) {
        this.name = name;
    }

    void turnOn() {
        System.out.println("Device turned on");
    }

    class Settings {
        void showSettings() {
            System.out.println("Settings opened for " + name);
        }
    }
}

class Light extends Device implements Controllable {
    Light(String name) {
        super(name);
    }

    @Override
    void turnOn() {
        System.out.println("Light turned on");
    }

    public void control() {
        System.out.println("Light controlled");
    }
}

class Fan extends Device {
    Fan(String name) {
        super(name);
    }

    @Override
    void turnOn() {
        System.out.println("Fan turned on");
    }
}

class DeviceThread extends Thread {
    String device;

    DeviceThread(String device) {
        this.device = device;
    }

    public void run() {
        System.out.println(device + " is working");
    }
}

public class SmartHomeAutomation {
    public static void main(String[] args) {
        String devices[] = {"Light", "Fan", "AC"};

        Light l = new Light("Hall Light");
        Fan f = new Fan("Ceiling Fan");

        l.turnOn();
        f.turnOn();
        l.control();

        Device.Settings s = l.new Settings();
        s.showSettings();

        new DeviceThread("Light").start();
        new DeviceThread("Fan").start();
    }
}
