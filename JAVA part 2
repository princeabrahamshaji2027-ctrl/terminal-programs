8. Smart Home Automation
interface Controllable {
    void controlDevice();
}

class Device {
    String name;

    Device(String name) {
        this.name = name;
    }

    void turnOn() {
        System.out.println("Device turned on");
    }
}

class Light extends Device implements Controllable {
    Light(String name) {
        super(name);
    }

    void turnOn() {
        System.out.println("Light turned on");
    }

    public void controlDevice() {
        System.out.println("Light controlled");
    }
}

class Fan extends Device implements Controllable {
    Fan(String name) {
        super(name);
    }

    void turnOn() {
        System.out.println("Fan turned on");
    }

    public void controlDevice() {
        System.out.println("Fan controlled");
    }
}

class Settings {
    void showSettings() {
        System.out.println("Device settings shown");
    }
}

class DeviceThread extends Thread {
    String device;

    DeviceThread(String device) {
        this.device = device;
    }

    public void run() {
        System.out.println(device + " is being controlled");
    }
}

public class SmartHomeAutomation {
    public static void main(String[] args) {
        Light l = new Light("Tube Light");
        Fan f = new Fan("Ceiling Fan");

        l.turnOn();
        f.turnOn();

        l.controlDevice();
        f.controlDevice();

        String devices[] = {"Tube Light", "Ceiling Fan", "Bulb"};
        for (int i = 0; i < devices.length; i++) {
            System.out.println(devices[i]);
        }

        Settings s = new Settings();
        s.showSettings();

        DeviceThread t1 = new DeviceThread("Light");
        DeviceThread t2 = new DeviceThread("Fan");

        t1.start();
        t2.start();
    }
}
